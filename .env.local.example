# ============================================
# UMGEBUNGSVARIABLEN - Agent Platform
# ============================================
# 1. Diese Datei kopieren und in ".env.local" umbenennen
# 2. Alle Werte mit deinen echten Keys ersetzen
# 3. Diese Datei NIEMALS in Git hochladen!
# ============================================

# --- CLERK (Authentication) ---
# Holen von: https://dashboard.clerk.com → Dein Projekt → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_DEIN_CLERK_KEY_HIER
CLERK_SECRET_KEY=sk_test_DEIN_CLERK_SECRET_HIER

# Clerk Weiterleitungen nach Login/Logout
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- SUPABASE (Datenbank) ---
# Holen von: https://supabase.com → Dein Projekt → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://DEIN_PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=DEIN_SUPABASE_ANON_KEY_HIER
SUPABASE_SERVICE_ROLE_KEY=DEIN_SUPABASE_SERVICE_ROLE_KEY_HIER

# --- ANTHROPIC (Managed Agents) ---
# Holen von: https://platform.claude.com → Settings → API Keys
# ACHTUNG: Dieser Key bleibt IMMER auf dem Server - niemals im Frontend!
ANTHROPIC_API_KEY=sk-ant-DEIN_ANTHROPIC_KEY_HIER

# --- STRIPE (Zahlungen) ---
# Holen von: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_DEIN_STRIPE_SECRET_HIER
STRIPE_WEBHOOK_SECRET=whsec_DEIN_WEBHOOK_SECRET_HIER

# --- APP URL ---
# Lokal: http://localhost:3000
# Auf Vercel: https://deine-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
